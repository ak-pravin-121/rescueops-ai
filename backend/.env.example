# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rescueops
DB_USERNAME=postgres
DB_PASSWORD=password

# --- JWT auth ---
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-real-256-bit-base64-secret
JWT_EXPIRATION_MS=604800000

# --- CORS (comma separated origins allowed to call this API) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Google AI Studio / Gemini ---
# Create a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Hibernate (use "validate" once your schema is stable, "update" for first run) ---
DDL_AUTO=update
SHOW_SQL=false

# --- Server port (Render/Railway inject PORT automatically) ---
PORT=8080
